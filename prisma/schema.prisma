generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PLAYER
}

enum CharacterStatus {
  ACTIVE
  ARCHIVED
}

enum ShopType {
  GUILD
  HONOR
}

enum CurrencyType {
  GOLD
  HONOR
}

enum ItemOwnershipType {
  PUBLIC
  PRIVATE
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
}

enum AuditAction {
  CHARACTER_GOLD_UPDATED
  CHARACTER_REPUTATION_UPDATED
  USER_HONOR_UPDATED
  PRIVATE_ITEM_CREATED
  PRIVATE_ITEM_DELETED
  MARKET_LISTED
  MARKET_CANCELLED
  MARKET_PURCHASED
  SHOP_PURCHASED
  SHOP_SELLBACK
  SHOP_ITEM_UPDATED
  SHOP_PASSWORD_POOL_REFRESHED
  CHARACTER_ARCHIVED
  CHARACTER_RESTORED
}

model User {
  id                String              @id @default(cuid())
  username          String              @unique
  displayName       String              @unique
  passwordHash      String
  role              UserRole            @default(PLAYER)
  honor             Int                 @default(0)
  isActive          Boolean             @default(true)
  currentCharacterId String?
  characters        Character[]
  currentCharacter  Character?          @relation("CurrentCharacter", fields: [currentCharacterId], references: [id], onDelete: SetNull)
  auditLogsAsActor  AuditLog[]          @relation("AuditActor")
  auditLogsAsTarget AuditLog[]          @relation("AuditTargetUser")
  passwordPools     OneTimePasswordPool[] @relation("PasswordPoolCreator")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([currentCharacterId])
}

model Character {
  id              String           @id @default(cuid())
  userId          String
  name            String
  gold            Int              @default(0)
  reputation      Int              @default(0)
  status          CharacterStatus  @default(ACTIVE)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  selectedByUsers User[]           @relation("CurrentCharacter")
  inventoryItems  InventoryItem[]
  sellingListings MarketListing[]  @relation("SellerCharacter")
  buyingListings  MarketListing[]  @relation("BuyerCharacter")
  auditLogs       AuditLog[]       @relation("AuditTargetCharacter")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userId, status])
  @@unique([userId, name])
}

model Shop {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  type        ShopType
  currency    CurrencyType
  description String?
  sortOrder   Int          @default(0)
  items       ShopItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model ShopItem {
  id             String          @id @default(cuid())
  shopId         String
  name           String
  description    String?
  category       String
  price          Int
  priceLabel     String?
  isActive       Boolean         @default(true)
  importedSource String?
  sortOrder      Int             @default(0)
  shop           Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  inventoryItems InventoryItem[] @relation("InventorySourceShopItem")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([shopId, category, isActive])
}

model InventoryItem {
  id               String            @id @default(cuid())
  characterId      String
  name             String
  description      String?
  quantity         Int               @default(1)
  unitPrice        Int               @default(0)
  ownershipType    ItemOwnershipType
  isListed         Boolean           @default(false)
  sourceShopItemId String?
  character        Character         @relation(fields: [characterId], references: [id], onDelete: Cascade)
  sourceShopItem   ShopItem?         @relation("InventorySourceShopItem", fields: [sourceShopItemId], references: [id], onDelete: SetNull)
  marketListing    MarketListing?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([characterId, ownershipType])
  @@index([sourceShopItemId])
}

model MarketListing {
  id                String        @id @default(cuid())
  inventoryItemId   String        @unique
  sellerCharacterId String
  buyerCharacterId  String?
  price             Int
  status            ListingStatus @default(ACTIVE)
  listedAt          DateTime      @default(now())
  soldAt            DateTime?
  inventoryItem     InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  sellerCharacter   Character     @relation("SellerCharacter", fields: [sellerCharacterId], references: [id], onDelete: Cascade)
  buyerCharacter    Character?    @relation("BuyerCharacter", fields: [buyerCharacterId], references: [id], onDelete: SetNull)

  @@index([status, listedAt])
  @@index([sellerCharacterId, status])
}

model OneTimePasswordPool {
  id              String            @id @default(cuid())
  createdByUserId String
  isActive        Boolean           @default(true)
  createdByUser   User              @relation("PasswordPoolCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  passwords       OneTimePassword[]
  createdAt       DateTime          @default(now())

  @@index([isActive, createdAt])
}

model OneTimePassword {
  id        String             @id @default(cuid())
  poolId    String
  code      String             @unique
  isUsed    Boolean            @default(false)
  usedAt    DateTime?
  pool      OneTimePasswordPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  createdAt DateTime           @default(now())

  @@index([poolId, isUsed])
}

model AuditLog {
  id                String      @id @default(cuid())
  actorUserId       String?
  targetUserId      String?
  targetCharacterId String?
  action            AuditAction
  entityType        String
  entityId          String?
  beforeValue       String?
  afterValue        String?
  note              String?
  actorUser         User?       @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetUser        User?       @relation("AuditTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetCharacter   Character?  @relation("AuditTargetCharacter", fields: [targetCharacterId], references: [id], onDelete: SetNull)
  createdAt         DateTime    @default(now())

  @@index([action, createdAt])
  @@index([targetCharacterId, createdAt])
  @@index([targetUserId, createdAt])
}
